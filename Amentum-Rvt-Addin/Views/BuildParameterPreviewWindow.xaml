<Window x:Class="AmentumRevit.Views.BuildParameterPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Amentum - Build Parameters"
        Width="1120" Height="720"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#003865" Padding="16,10">
            <TextBlock Text="Amentum - Build Parameters"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"/>
        </Border>
        <Border DockPanel.Dock="Bottom" Background="#F5F7FA" BorderBrush="#D0D8E0" BorderThickness="0,1,0,0" Padding="10">
            <DockPanel>
                <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="#555"/>
                <Button Content="Cancel" DockPanel.Dock="Right" Padding="16,6" Click="Cancel_Click"/>
            </DockPanel>
        </Border>
        <wv2:WebView2 x:Name="PreviewWebView"/>
    </DockPanel>
</Window>
