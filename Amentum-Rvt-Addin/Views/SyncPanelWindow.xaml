<Window x:Class="AmentumRevit.Views.SyncPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AmentumRevit.Views"
        Title="Amentum — Sync Panel"
        Width="1100" Height="650"
        MinWidth="800" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Icon="{x:Null}">

    <Window.Resources>
        <!-- Amentum navy / orange palette -->
        <SolidColorBrush x:Key="AmentumNavy"  Color="#003865"/>
        <SolidColorBrush x:Key="AmentumOrange" Color="#E87722"/>
        <SolidColorBrush x:Key="AmentumLight"  Color="#F5F7FA"/>
        <SolidColorBrush x:Key="DirtyBrush"    Color="#FFF3CD"/>

        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AmentumNavy}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="16,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AmentumOrange}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Highlight dirty rows -->
        <Style x:Key="DirtyRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDirty}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DirtyBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- ── Header bar ──────────────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource AmentumNavy}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Amentum"
                           Foreground="{StaticResource AmentumOrange}"
                           FontSize="18" FontWeight="Bold"/>
                <TextBlock Text=" — Sync Panel"
                           Foreground="White"
                           FontSize="18" FontWeight="Light"
                           Margin="2,0,0,0"/>
                <TextBlock x:Name="ElementCountLabel"
                           Foreground="#A0B8CC"
                           FontSize="13"
                           VerticalAlignment="Bottom"
                           Margin="16,0,0,4"/>
            </StackPanel>
        </Border>

        <!-- ── Filter / search bar ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource AmentumLight}"
                BorderBrush="#D0D8E0" BorderThickness="0,0,0,1"
                Padding="12,6">
            <DockPanel>
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="FilterBox"
                         Width="240"
                         VerticalAlignment="Center"
                         TextChanged="FilterBox_TextChanged"
                         ToolTip="Type to filter by category, name, or parameter key"/>
                <CheckBox x:Name="ShowDirtyOnly"
                          Content="Show edited only"
                          VerticalAlignment="Center"
                          Margin="16,0,0,0"
                          Checked="DirtyFilter_Changed"
                          Unchecked="DirtyFilter_Changed"/>
                <TextBlock x:Name="StatusLabel"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Foreground="#555"/>
            </DockPanel>
        </Border>

        <!-- ── Bottom action bar ───────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource AmentumLight}"
                BorderBrush="#D0D8E0" BorderThickness="0,1,0,0"
                Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button x:Name="ExportBtn"
                            Content="Export to Excel…"
                            Style="{StaticResource HeaderButton}"
                            Background="#555"
                            Click="ExportBtn_Click"
                            ToolTip="Save current view to a new Excel workbook"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ClearBtn"
                            Content="Clear edits"
                            Style="{StaticResource HeaderButton}"
                            Background="#888"
                            Click="ClearBtn_Click"
                            Margin="0,0,8,0"/>
                    <Button x:Name="ApplyBtn"
                            Content="Apply changes"
                            Style="{StaticResource HeaderButton}"
                            Click="ApplyBtn_Click"
                            ToolTip="Write all edited values back to the Revit model"
                            Margin="0,0,8,0"/>
                    <Button Content="Cancel"
                            Padding="16,6"
                            Click="CancelBtn_Click"/>
                </StackPanel>
                <TextBlock x:Name="DirtyCountLabel"
                           VerticalAlignment="Center"
                           Foreground="#555"/>
            </DockPanel>
        </Border>

        <!-- ── Main DataGrid ───────────────────────────────────────────────── -->
        <DataGrid x:Name="MainGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F0F4F8"
                  RowStyle="{StaticResource DirtyRowStyle}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  EnableRowVirtualization="True"
                  Margin="0">

            <DataGrid.Columns>

                <!-- Read-only identity columns -->
                <DataGridTextColumn Header="Category"
                                    Binding="{Binding Category}"
                                    IsReadOnly="True" Width="130"/>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding Name}"
                                    IsReadOnly="True" Width="180"/>
                <DataGridTextColumn Header="ElementId"
                                    Binding="{Binding ElementId}"
                                    IsReadOnly="True" Width="80"/>
                <DataGridTextColumn Header="Parameter"
                                    Binding="{Binding ParamKey}"
                                    IsReadOnly="True" Width="160"/>
                <DataGridTextColumn Header="Current Value"
                                    Binding="{Binding CurrentValue}"
                                    IsReadOnly="True" Width="200">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#444"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Editable new-value column -->
                <DataGridTextColumn Header="New Value ✏"
                                    Binding="{Binding NewValue, UpdateSourceTrigger=PropertyChanged}"
                                    IsReadOnly="False"
                                    Width="*">
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="Background" Value="#FFFEF0"/>
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
